<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/pink_background"
    android:padding="16dp">

    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentStart="true"
        android:layout_alignParentTop="true"
        android:layout_marginStart="16dp"
        android:layout_marginTop="32dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="12dp"
            android:src="@mipmap/ic_launcher" />

        <TextView
            android:id="@+id/titleTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SafeRoute"
            android:textColor="@color/pink_text_primary"
            android:textSize="40sp"
            android:textStyle="bold" />

    </LinearLayout>

    <ImageButton
        android:id="@+id/infoButton"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="32dp"
        android:layout_marginEnd="16dp"
        android:background="@drawable/info_button_background"
        android:src="@drawable/ic_question_mark" />

    <Button
        android:id="@+id/sosButton"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:layout_below="@id/headerLayout"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="60dp"
        android:background="@drawable/rounded_button_background"
        android:text="SOS"
        android:textColor="@color/white"
        android:textSize="48sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/sosButton"
        android:layout_marginTop="24dp"
        android:orientation="vertical">

        <Button
            android:id="@+id/shareLocationButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="8dp"
            android:background="@drawable/rounded_corner_button"
            android:minHeight="60dp"
            android:text="Share Location (WhatsApp)"
            android:textColor="@color/pink_on_primary" />

        <Button
            android:id="@+id/fakeCallButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="8dp"
            android:background="@drawable/rounded_corner_button"
            android:minHeight="60dp"
            android:text="Fake Call"
            android:textColor="@color/pink_on_primary" />

        <Button
            android:id="@+id/sirenButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="8dp"
            android:background="@drawable/rounded_corner_button"
            android:minHeight="60dp"
            android:text="Siren"
            android:textColor="@color/pink_on_primary" />

        <Button
            android:id="@+id/settingsButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="8dp"
            android:background="@drawable/rounded_corner_button"
            android:minHeight="60dp"
            android:text="Manage Contacts"
            android:textColor="@color/pink_on_primary" />

    </LinearLayout>

</RelativeLayout>